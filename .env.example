# Performa Studio - Environment Configuration

# API URL - points to the api-gateway
# Local dev (with docker-compose): http://localhost:3000/api
# Production (EC2): http://api-gateway:3000/api (internal) or your public domain
VITE_API_URL=http://localhost:3000/api

# Port to expose studio on (default: 3001, since api-gateway uses 3000)
STUDIO_PORT=3001
